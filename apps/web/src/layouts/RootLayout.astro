---
/**
 * RootLayout — html shell shared by every page.
 *
 * Composition:
 *   <body>
 *     [skip-to-content link]
 *     <TopNav />            (floating pill, fixed)
 *     <slot />              (page content)
 *     <SiteFooter />        (only when showFooter prop is true —
 *                            marketing + onboarding pages only)
 *   </body>
 *
 * The body is flex column + min-h-svh so the footer (when shown) stays at
 * the bottom even when a page's content is short. App-shell pages
 * (/profile, /play, …) opt out of the footer entirely.
 */
import "~/styles/globals.css";
import TopNav from "~/components/TopNav.astro";
import SiteFooter from "~/components/SiteFooter.astro";
import { getCurrentUser } from "~/lib/auth";

interface Props {
  title?: string;
  description?: string;
  /**
   * Render <SiteFooter />? Footer carries marketing-shell links
   * (About / How to play / Privacy / Terms) that are only relevant on
   * marketing + onboarding pages — not inside the app shell. Default
   * false; opt in from index.astro / login.astro / signup.astro.
   */
  showFooter?: boolean;
  /**
   * Render <TopNav />? Defaults to true. App-shell pages that own their
   * own chrome (e.g. /profile while we figure out the authed-variant
   * TopNav) can opt out.
   */
  showTopNav?: boolean;
}

const {
  title = "4thewin",
  description = "Connect 4, but smarter. Play the AI in your browser.",
  showFooter = false,
  showTopNav = true,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "http://localhost:4321").toString();

// One backend call per request to drive the TopNav's authed/anon variant.
// We fetch the full user (not just a boolean) so the topnav can render the
// avatar squircle + initial without an extra round-trip on the client.
// Adds ~5ms compose-internal. See apps/web/docs/authed-nav-roadmap.md.
const user = await getCurrentUser(Astro);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>

    {/*
      Theme bootstrap — must run BEFORE paint to avoid FOUC.
      Reads localStorage first, falls back to prefers-color-scheme.
      Adds either `light` or `dark` class to <html>; never both.

      Also wires the click handler for any [data-theme-toggle] button (used by
      TopNav). Pure inline JS — no React island — so the icon is rendered by
      Astro at SSR (with dark:hidden / dark:block CSS rules picking which one
      shows) and there's no hydration flicker.
    */}
    <script is:inline>
      (function () {
        function setTheme(theme) {
          var root = document.documentElement;
          // Strip every transition for the duration of this paint.
          // Without this, body bg / pawn shadows / scrollbars snap
          // instantly while elements with transition-colors slowly fade
          // through gray — visible 'shimmer'. With it, the whole page
          // changes mode in one frame (matches GitHub / Linear / Slack).
          // Re-enabled on the next animation frame so user-initiated
          // hover transitions resume working immediately afterwards.
          root.classList.add("disable-transitions");
          root.classList.remove("light", "dark");
          root.classList.add(theme);
          root.style.colorScheme = theme;
          // Force a reflow so the browser commits the no-transition state
          // before any color changes paint, then drop the class.
          // eslint-disable-next-line no-unused-expressions
          void root.offsetHeight;
          requestAnimationFrame(function () {
            root.classList.remove("disable-transitions");
          });
        }

        // Initial theme: localStorage → prefers-color-scheme → "light".
        try {
          var stored = localStorage.getItem("theme");
          var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          var theme = stored === "dark" || stored === "light" ? stored : prefersDark ? "dark" : "light";
          setTheme(theme);
        } catch (e) {
          /* localStorage unavailable (private mode / file://) — fall through */
        }

        // Click handler — delegated on document so it works for any
        // [data-theme-toggle] button across the app.
        document.addEventListener("click", function (e) {
          var btn = e.target && e.target.closest && e.target.closest("[data-theme-toggle]");
          if (!btn) return;
          var current = document.documentElement.classList.contains("dark") ? "dark" : "light";
          var next = current === "dark" ? "light" : "dark";
          setTheme(next);
          try { localStorage.setItem("theme", next); } catch (e) {}
        });

        // Follow OS preference live when the user hasn't explicitly chosen.
        try {
          window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", function (e) {
            if (localStorage.getItem("theme") === null) {
              setTheme(e.matches ? "dark" : "light");
            }
          });
        } catch (e) {}

        // Expose a window-level API so React islands (e.g. SettingsAppearance)
        // can drive the same code path. Accepts "light" | "dark" | "auto":
        //   - light / dark: stores + applies
        //   - auto: clears storage, picks based on prefers-color-scheme now
        //     and lets the OS-preference listener take over going forward.
        window.__4thewinSetTheme = function (theme) {
          try {
            if (theme === "auto") {
              localStorage.removeItem("theme");
              var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
              setTheme(prefersDark ? "dark" : "light");
            } else {
              localStorage.setItem("theme", theme);
              setTheme(theme);
            }
          } catch (e) {
            // localStorage unavailable — apply the requested mode without persisting.
            if (theme === "light" || theme === "dark") setTheme(theme);
          }
        };
        // Reads the current effective choice (light / dark / auto) for the
        // /settings radio to initialise to.
        window.__4thewinGetTheme = function () {
          try {
            var stored = localStorage.getItem("theme");
            if (stored === "light" || stored === "dark") return stored;
            return "auto";
          } catch (e) {
            return "auto";
          }
        };
      })();
    </script>
  </head>
  <body class="flex min-h-svh flex-col font-sans md:h-svh md:overflow-hidden">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:rounded-md focus:bg-foreground focus:px-3 focus:py-2 focus:text-background"
    >
      Skip to content
    </a>
    {showTopNav && <TopNav user={user} />}
    <div class="flex flex-1 flex-col md:min-h-0 md:overflow-y-auto">
      <slot />
    </div>
    {showFooter && <SiteFooter />}

    {/* DEV: 8-column grid overlay — toggle via the button below.
        Hidden by default; shown when <html> has the .grid-on class
        (controlled by the script + button). Appears on every page. */}
    <div class="grid-overlay pointer-events-none fixed inset-0 z-50" aria-hidden="true">
      <div class="mx-auto h-full w-full max-w-7xl px-margin-mobile md:px-margin-desktop">
        <div class="grid h-full grid-cols-8 gap-gutter">
          {Array.from({ length: 8 }).map((_, i) => (
            <div class="flex items-start justify-center border-x border-accent/30 bg-accent/10 pt-2">
              <span class="font-mono text-xs text-accent/70">{i + 1}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    {/* Grid toggle button — fixed bottom-right, always visible. */}
    <button
      id="grid-toggle"
      type="button"
      class="fixed bottom-4 right-4 z-[100] rounded-full border border-border bg-surface px-3 py-1.5 font-mono text-mono-sm uppercase text-muted-foreground shadow-lg transition-colors hover:bg-foreground hover:text-background"
      aria-label="Toggle 8-column grid overlay"
    >
      Grid
    </button>

    {/* Grid overlay state: read from localStorage on load, toggle on click. */}
    <script is:inline>
      (function () {
        var html = document.documentElement;
        try {
          if (localStorage.getItem("grid-overlay") === "on") {
            html.classList.add("grid-on");
          }
        } catch (e) { /* localStorage unavailable */ }
        document.addEventListener("click", function (e) {
          var btn = e.target && e.target.closest && e.target.closest("#grid-toggle");
          if (!btn) return;
          var on = html.classList.toggle("grid-on");
          try {
            localStorage.setItem("grid-overlay", on ? "on" : "off");
          } catch (e) {}
        });
      })();
    </script>

    {/*
      TopNav scroll-hide.

      The pill is fixed and we want it to slide up + fade out once the
      user has scrolled past a small threshold, regardless of which
      element is doing the scrolling:
        - mobile: body min-h-svh, document/window scrolls
        - desktop: body md:h-svh + md:overflow-hidden, slot wrapper scrolls

      We attach a scroll listener to both window and the slot wrapper;
      whichever fires drives the same body.is-scrolled toggle. CSS in
      globals.css does the visual work.
    */}
    <script is:inline>
      (function () {
        var THRESHOLD = 32;
        var slot = document.querySelector("body > div.flex.flex-1");
        var body = document.body;

        function onScroll() {
          var y = (slot && slot.scrollTop) || window.scrollY || 0;
          body.classList.toggle("is-scrolled", y > THRESHOLD);
        }

        window.addEventListener("scroll", onScroll, { passive: true });
        if (slot) slot.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      })();
    </script>
  </body>
</html>
