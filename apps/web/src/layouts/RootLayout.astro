---
/**
 * RootLayout — html shell shared by every page.
 *
 * Composition:
 *   <body>
 *     [skip-to-content link]
 *     <TopNav />            (floating pill, fixed)
 *     <slot />              (page content)
 *     <SiteFooter />
 *   </body>
 *
 * The body is flex column + min-h-svh so the footer stays at the bottom
 * even when a page's content is short.
 */
import "~/styles/globals.css";
import TopNav from "~/components/TopNav.astro";
import SiteFooter from "~/components/SiteFooter.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "4thewin",
  description = "Connect 4, but smarter. Play the AI in your browser.",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "http://localhost:4321").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>

    {/*
      Theme bootstrap — must run BEFORE paint to avoid FOUC.
      Reads localStorage first, falls back to prefers-color-scheme.
      Adds either `light` or `dark` class to <html>; never both.
    */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          var theme = stored === "dark" || stored === "light" ? stored : prefersDark ? "dark" : "light";
          var root = document.documentElement;
          root.classList.remove("light", "dark");
          root.classList.add(theme);
          root.style.colorScheme = theme;
        } catch (e) {
          /* localStorage may be unavailable (private mode / file://) — fall through to default light */
        }
      })();
    </script>
  </head>
  <body class="flex min-h-svh flex-col font-sans">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:rounded-md focus:bg-foreground focus:px-3 focus:py-2 focus:text-background"
    >
      Skip to content
    </a>
    <TopNav />
    <div class="flex-1">
      <slot />
    </div>
    <SiteFooter />
  </body>
</html>
