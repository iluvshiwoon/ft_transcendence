---
/**
 * TopNav — floating pill bar.
 *
 * Static parts are pure Astro (zero JS shipped). The shadcn <Button> primitive
 * is rendered server-side only — no client:* directive. ThemeToggle is the
 * only React island.
 *
 * Implementation note: <Button asChild><a/></Button> doesn't work cleanly under
 * Astro because Astro's <a> isn't a real React element when it reaches Radix
 * Slot — props don't merge, the anchor renders with no className. So the
 * Login / Sign up CTAs apply `buttonVariants()` to the <a> directly. Same
 * visual contract, no Slot.
 *
 * Hamburger button is currently inert. It'll become a shadcn DropdownMenu in
 * a future task once we have the menu items defined.
 */
import { Button, buttonVariants } from "~/components/ui/button";
import { ThemeToggle } from "~/components/ThemeToggle";
import { cn } from "~/lib/utils";

// Mock auth gate: treat /profile as the signed-in state until real auth lands.
const isAuthed = Astro.url.pathname.startsWith("/profile");
---

<header
  class:list={[
    "fixed top-6 left-1/2 -translate-x-1/2 z-50",
    "w-[calc(100%-2*var(--spacing-margin-mobile))] md:w-auto md:max-w-[760px]",
    "flex items-center justify-between gap-5 md:gap-8",
    "rounded-full border border-foreground bg-muted",
    "px-5 py-2 md:px-7 md:py-2.5",
    "shadow-sm",
  ]}
  aria-label="Site navigation"
>
  {/* Left group: brand mark + menu placeholder */}
  <div class="flex items-center gap-3 md:gap-4">
    <a
      href="/"
      class="font-display italic text-3xl md:text-4xl tracking-tight leading-none text-foreground"
      aria-label="4thewin — home"
    >
      4
    </a>
    <Button
      variant="ghost"
      size="icon"
      aria-label="Open menu"
      title="Open menu"
      data-todo-integration="hamburger menu — wire to shadcn DropdownMenu. On mobile, include a Login entry (the desktop pill exposes Login directly; mobile hides it for breathing room)."
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4" aria-hidden="true">
        <line x1="4" x2="20" y1="6" y2="6"></line>
        <line x1="4" x2="20" y1="12" y2="12"></line>
        <line x1="4" x2="20" y1="18" y2="18"></line>
      </svg>
    </Button>
  </div>

  {/* Right group: theme toggle + auth CTAs */}
  <div class="flex items-center gap-2.5 md:gap-3">
    <ThemeToggle client:only="react" />

    {/* TEMP: until auth lands, expose /profile from any page. */}
    <a
      href="/profile"
      class={cn(buttonVariants({ variant: "ghost", size: "pill" }), "hidden sm:inline-flex")}
    >
      Profile
    </a>

    {isAuthed ? (
      <a
        href="/profile"
        class={cn(buttonVariants({ variant: "brand-outline", size: "pill" }))}
      >
        Profile
      </a>
    ) : (
      <>
        <a
          href="/login"
          class={cn(buttonVariants({ variant: "brand-outline", size: "pill" }), "hidden sm:inline-flex")}
          data-todo-integration="POST /api/auth/login — wire to apps/server"
        >
          Login
        </a>

        <a
          href="/signup"
          class={cn(buttonVariants({ variant: "brand-filled", size: "pill" }), "gap-1.5")}
          data-todo-integration="POST /api/auth/signup — wire to apps/server"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
          Sign up
        </a>
      </>
    )}
  </div>
</header>
