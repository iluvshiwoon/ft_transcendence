---
/**
 * Step1Save — "Save your spot": carry-over story + auth method picker.
 *
 * The displayed rank/score is a placeholder for now. Real values bind to the
 * anonymous demo session once the game module emits one (TODO).
 *
 * - Continue with email → /signup?step=2
 * - Continue with 42    → /api/auth/42 (existing backend OAuth start)
 *   On callback, the user lands at / today; once the backend is wired to
 *   redirect signup-flow callbacks to /signup?step=3, OAuth users skip step 2.
 */
import { buttonVariants } from "~/components/ui/button";
import { cn } from "~/lib/utils";

// TODO(integration): replace with real anonymous-session score + computed rank.
//   Hook point: read from localStorage.4thewin_session_score (set by GameDemo
//   on game-finished). Falls back to placeholder copy if absent.
const placeholderRank = 4;
const placeholderRating = 2569;
---

<header class="flex flex-col gap-3">
  <h1 class="font-display italic font-light tracking-wide text-3xl text-foreground leading-none">
    Save your spot
  </h1>
  <p class="text-base text-muted-foreground">
    You finished your demo at <span class="font-bold text-foreground">#{placeholderRank}</span>
    on the leaderboard with a rating of <span class="font-mono font-bold text-foreground tabular-nums">{placeholderRating}</span>.
    Sign up to lock that in and start climbing.
  </p>
</header>

<div class="flex flex-col gap-3 pt-2">
  <a
    href="/signup?step=2"
    class={cn(buttonVariants({ variant: "brand-filled", size: "pill" }), "h-11 gap-2 px-6 text-mono-md")}
    data-todo-integration="advance to credentials step"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4" aria-hidden="true">
      <rect width="20" height="16" x="2" y="4" rx="2"></rect>
      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
    </svg>
    Continue with email
  </a>

  <a
    href="/api/auth/42"
    class={cn(buttonVariants({ variant: "brand-outline", size: "pill" }), "h-11 gap-2 px-6 text-mono-md")}
    data-todo-integration="OAuth callback should redirect to /signup?step=3 for new users"
  >
    Continue with 42
  </a>
</div>

<p class="pt-2 text-center font-mono text-mono-sm uppercase text-muted-foreground">
  Already have an account? <a href="/login" class="text-foreground underline decoration-transparent underline-offset-4 transition-colors hover:decoration-accent hover:text-accent">Sign in</a>
</p>
