---
/**
 * Step4Welcome — final step. Connect-4 progress flash plays on landing
 * (handled by SignupShell's SignupProgress receiving current=4; the
 * [data-current="4"] CSS cascade in globals.css orchestrates token-flash
 * + line-draw).
 *
 * Single CTA: Play. Lobbies, friends search, and rematch flows all live
 * inside /play once those modules ship — keeping a single button here
 * avoids prematurely committing to navigation that doesn't exist yet.
 */
import { buttonVariants } from "~/components/ui/button";
import { cn } from "~/lib/utils";
---

<header class="flex flex-col gap-4">
  <h1 class="font-display italic font-light tracking-wide text-3xl text-foreground leading-none">
    You're in.
  </h1>
  <p class="text-base text-muted-foreground">
    Your spot is saved. Time to play.
  </p>
</header>

<div class="flex flex-col gap-4 pt-4">
  <a
    href="/play"
    class={cn(buttonVariants({ variant: "brand-filled", size: "pill" }), "h-11 gap-2 px-6 text-mono-md")}
  >
    Play →
  </a>
</div>
