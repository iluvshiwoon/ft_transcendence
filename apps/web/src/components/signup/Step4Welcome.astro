---
/**
 * Step4Welcome — final step. Connect-4 progress flash plays on landing
 * (handled by SignupShell's SignupProgress receiving current=4; the [data-current="4"]
 * CSS cascade in globals.css orchestrates token-flash + line-draw).
 *
 * Three CTAs. All point to /play for now (multiplayer + lobbies + friends
 * don't exist yet); we'll re-target when those land.
 */
import { buttonVariants } from "~/components/ui/button";
import { cn } from "~/lib/utils";
---

<header class="flex flex-col gap-3">
  <h1 class="font-display italic font-light tracking-wide text-3xl text-foreground leading-none">
    You're in.
  </h1>
  <p class="text-base text-muted-foreground">
    Your spot is saved. What's next?
  </p>
</header>

<div class="flex flex-col gap-3 pt-2">
  <a
    href="/play"
    class={cn(buttonVariants({ variant: "brand-filled", size: "pill" }), "h-11 gap-2 px-6 text-mono-md")}
    data-todo-integration="should land back at / for an immediate AI rematch once GameDemo is wired"
  >
    Rematch the AI
  </a>

  <a
    href="/play"
    class={cn(buttonVariants({ variant: "brand-outline", size: "pill" }), "h-11 gap-2 px-6 text-mono-md")}
    data-todo-integration="route to the lobbies list page once Tim's lobby module ships"
  >
    Browse lobbies
  </a>

  <a
    href="/play"
    class={cn(buttonVariants({ variant: "brand-outline", size: "pill" }), "h-11 gap-2 px-6 text-mono-md")}
    data-todo-integration="route to friends search once friends UI ships"
  >
    Find a friend
  </a>
</div>
