---
/**
 * /about — what 4thewin is and who built it.
 * Static prose page. Editorial template matching /privacy + /terms.
 */
import RootLayout from "~/layouts/RootLayout.astro";

const stack = [
  { label: "Frontend", value: "Astro + React, Tailwind CSS" },
  { label: "Backend", value: "Fastify, Socket.io, PostgreSQL + Drizzle" },
  { label: "Security", value: "ModSecurity WAF, HashiCorp Vault, JWT" },
  { label: "Infra", value: "Podman containers, single-command deploy" },
];
---

<RootLayout title="4thewin — About" description="What 4thewin is and who built it.">
  <main
    id="main"
    class="mx-auto w-full max-w-3xl flex-1 overflow-y-auto px-margin-mobile pt-[120px] pb-20 md:pt-[150px]"
  >
    <header class="flex flex-col gap-4">
      <span class="font-mono text-mono-sm uppercase text-accent">About</span>
      <h1 class="font-display text-5xl font-semibold tracking-tight text-foreground md:text-6xl">
        Connect 4, <span class="italic font-light">but smarter.</span>
      </h1>
    </header>

    <p class="mt-8 font-display text-xl font-light italic leading-relaxed text-foreground/70">
      Play a sharp AI right in your browser — or sign up to challenge other
      players, track your stats, chat, and climb the leaderboard.
    </p>

    <hr class="mt-10 border-t border-border" />

    <div class="mt-10 flex flex-col">
      <section class="grid gap-3 py-8 md:grid-cols-[3rem_1fr] md:gap-8">
        <span class="font-mono text-mono-md text-accent md:pt-1">01</span>
        <div class="flex flex-col gap-3">
          <h2 class="font-display text-2xl font-semibold tracking-tight text-foreground">The project</h2>
          <p class="leading-relaxed text-foreground/80">
            The final group project of the 42 Common Core — a full-stack web app
            built from scratch: real-time multiplayer over WebSockets, an AI
            opponent using minimax with alpha-beta pruning, user accounts, a
            friends system, in-app chat and notifications, all behind a hardened
            security layer.
          </p>
        </div>
      </section>

      <section class="grid gap-3 border-t border-border/60 py-8 md:grid-cols-[3rem_1fr] md:gap-8">
        <span class="font-mono text-mono-md text-accent md:pt-1">02</span>
        <div class="flex flex-col gap-4">
          <h2 class="font-display text-2xl font-semibold tracking-tight text-foreground">Under the hood</h2>
          <dl class="flex flex-col divide-y divide-border/60">
            {stack.map((row) => (
              <div class="flex flex-col gap-1 py-3 sm:flex-row sm:items-baseline sm:gap-6">
                <dt class="font-mono text-mono-sm uppercase text-muted-foreground sm:w-28 sm:shrink-0">
                  {row.label}
                </dt>
                <dd class="text-foreground/80">{row.value}</dd>
              </div>
            ))}
          </dl>
        </div>
      </section>

      <section class="grid gap-3 border-t border-border/60 py-8 md:grid-cols-[3rem_1fr] md:gap-8">
        <span class="font-mono text-mono-md text-accent md:pt-1">03</span>
        <div class="flex flex-col gap-3">
          <h2 class="font-display text-2xl font-semibold tracking-tight text-foreground">The team</h2>
          <p class="leading-relaxed text-foreground/80">
            Built by a team of 42 students, each owning a slice of the stack:
            backend, frontend, cybersecurity, and project management.
          </p>
        </div>
      </section>
    </div>
  </main>
</RootLayout>
