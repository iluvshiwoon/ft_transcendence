---
/**
 * Landing page — / (home).
 *
 * Composition:
 *   - TopNav (in RootLayout) floats above
 *   - sr-only <h1> for SEO + screen readers (the brand statement)
 *   - <Headline> kicker centered above the 3-column grid
 *   - 3-column grid (items-start so all columns share the board's top baseline):
 *       AITelemetry (3 cols, left)
 *       Board       (6 cols, centered)
 *       Leaderboard (3 cols, right)
 *   - Mobile: Headline → Board → AITelemetry → Leaderboard via order classes
 *
 * AITelemetry and Leaderboard each render their own <section> with a labelled
 * h2 (the AITelemetry h2 is sr-only because the wireframe doesn't have a
 * visible label there). Headline is an <h2 role="status"> with aria-live
 * announcing game state changes.
 *
 * All three columns render SSR-only — no JS shipped today. When Tim's game
 * module lands, this page will wrap them in a <GameDemo client:load> island
 * that owns shared state.
 *
 * TODO(integration): wrap <AITelemetry/>, <Board/>, and <Leaderboard/> in a
 * single <GameDemo client:load> island that subscribes to the AI worker,
 * propagates board state, and emits "game:finished" so the leaderboard can
 * replace its dashed slot with a real row + signup CTA.
 */
import RootLayout from "~/layouts/RootLayout.astro";
import Headline from "~/components/landing/Headline.astro";
import { Board, type BoardVariant } from "~/components/landing/Board";
import { AITelemetry } from "~/components/landing/AITelemetry";
import { Leaderboard } from "~/components/landing/Leaderboard";

// EXPERIMENT — board variant from ?board=X. Remove after a direction is picked.
const VALID_VARIANTS: BoardVariant[] = [
  "default",
  "branded",
  "glass",
  "wood",
  "none",
  "recessed",
  "liquid-glass",
  "raised",
];
const requested = Astro.url.searchParams.get("board") ?? "default";
const boardVariant: BoardVariant = VALID_VARIANTS.includes(requested as BoardVariant)
  ? (requested as BoardVariant)
  : "default";

const VARIANT_LABELS: Record<BoardVariant, string> = {
  default: "Default",
  branded: "Branded",
  glass: "Glass",
  wood: "Wood",
  none: "No plate",
  recessed: "Recessed",
  "liquid-glass": "Liquid Glass",
  raised: "Raised",
};
---

<RootLayout
  title="4thewin — Connect 4, but smarter"
  description="Play Connect 4 against an AI in your browser. No signup needed to start."
>
  <main
    id="main"
    class="mx-auto w-full max-w-7xl px-margin-mobile pt-28 pb-12 md:px-margin-desktop md:pt-32"
  >
    {/* Visually hidden but read aloud by screen readers and indexed by search engines. */}
    <h1 class="sr-only">4thewin — Connect 4, but smarter</h1>

    {/* Hero kicker — centered above the 3-column grid */}
    <div class="mb-10 flex justify-center md:mb-12">
      <Headline state="your-turn" />
    </div>

    <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-gutter md:items-start">

      {/* AITelemetry — desktop left, mobile after the board.
          On desktop the panel sits at 80% opacity by default and fades up to
          full on hover or focus-within, so it reads as ambient context for
          the board (the actual hero) rather than co-equal content. Mobile
          keeps full opacity since the panels are stacked, not peripheral. */}
      <div class="order-2 md:order-1 md:col-span-3 flex justify-center md:opacity-80 md:transition-opacity md:duration-300 md:hover:opacity-100 md:focus-within:opacity-100">
        <AITelemetry />
      </div>

      {/* Board — centered horizontally inside its column */}
      <div class="order-1 md:order-2 md:col-span-6 flex justify-center">
        <Board variant={boardVariant} />
      </div>

      {/* Leaderboard — desktop right, mobile last.
          Same dim-on-default / restore-on-hover treatment as AITelemetry. */}
      <div class="order-3 md:order-3 md:col-span-3 flex justify-center md:opacity-80 md:transition-opacity md:duration-300 md:hover:opacity-100 md:focus-within:opacity-100">
        <Leaderboard />
      </div>

    </div>
  </main>

  {/* EXPERIMENT — SVG filter for the liquid-glass board variant.
      Defines the lg-dist filter referenced by `.lg-filter` in globals.css.
      feTurbulence generates fractal noise; feDisplacementMap warps the
      backdrop using the noise as a displacement map → refraction effect.
      Browser support: works in Chromium (Chrome/Edge); falls back to a
      plain frosted blur in Safari/Firefox where backdrop-filter + SVG
      filter URL isn't supported. Adapted from cssscript.com lg-* recipe. */}
  <svg aria-hidden="true" style="position:absolute;width:0;height:0;pointer-events:none;">
    <defs>
      <filter id="lg-dist" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence type="fractalNoise" baseFrequency="0.008 0.008" numOctaves="2" seed="92" result="noise" />
        <feGaussianBlur in="noise" stdDeviation="2" result="blurred" />
        <feDisplacementMap in="SourceGraphic" in2="blurred" scale="70" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>

  {/* EXPERIMENT — board variant toggle. Floating bottom-right, fixed.
      Remove this entire block + the variant prop on <Board /> + the URL
      param logic in the frontmatter once a direction is picked. */}
  <div
    class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 rounded-lg border border-border bg-surface p-3 shadow-2xl"
    aria-label="Board variant picker (experiment)"
  >
    <p class="font-mono text-mono-sm uppercase text-muted-foreground">Board style</p>
    <div class="flex flex-wrap gap-1.5">
      {VALID_VARIANTS.map((v) => {
        const isActive = v === boardVariant;
        return (
          <a
            href={`/?board=${v}`}
            class:list={[
              "rounded-md border px-2.5 py-1 font-mono text-mono-sm transition-colors",
              isActive
                ? "border-foreground bg-foreground text-background"
                : "border-border bg-surface text-foreground hover:border-foreground",
            ]}
            aria-current={isActive ? "true" : undefined}
          >
            {VARIANT_LABELS[v]}
          </a>
        );
      })}
    </div>
  </div>
</RootLayout>
