---
/**
 * Landing page — / (home).
 *
 * Composition:
 *   - TopNav (in RootLayout) floats above
 *   - sr-only <h1> for SEO + screen readers (the brand statement)
 *   - <Headline> kicker centered above the 3-column grid
 *   - 3-column grid (items-start so all columns share the board's top baseline):
 *       AITelemetry (3 cols, left)
 *       Board       (6 cols, centered)
 *       Leaderboard (3 cols, right)
 *   - Mobile: Headline → Board → AITelemetry → Leaderboard via order classes
 *
 * AITelemetry and Leaderboard each render their own <section> with a labelled
 * h2 (the AITelemetry h2 is sr-only because the wireframe doesn't have a
 * visible label there). Headline is an <h2 role="status"> with aria-live
 * announcing game state changes.
 *
 * All three columns render SSR-only — no JS shipped today. When Tim's game
 * module lands, this page will wrap them in a <GameDemo client:load> island
 * that owns shared state.
 *
 * TODO(integration): wrap <AITelemetry/>, <Board/>, and <Leaderboard/> in a
 * single <GameDemo client:load> island that subscribes to the AI worker,
 * propagates board state, and emits "game:finished" so the leaderboard can
 * replace its dashed slot with a real row + signup CTA.
 */
import RootLayout from "~/layouts/RootLayout.astro";
import Headline from "~/components/landing/Headline.astro";
import { Board, type BoardVariant } from "~/components/landing/Board";
import { AITelemetry } from "~/components/landing/AITelemetry";
import { Leaderboard } from "~/components/landing/Leaderboard";

// Board variant from ?board=X — liquid-glass is the chosen default. The
// other variants are kept (Board.tsx + globals.css) so we can switch skins
// later without reimplementing them. No visible toggle in the UI; switch
// via URL during dev (e.g. /?board=raised).
const VALID_VARIANTS: BoardVariant[] = [
  "default",
  "branded",
  "glass",
  "wood",
  "none",
  "recessed",
  "liquid-glass",
  "raised",
];
const requested = Astro.url.searchParams.get("board") ?? "liquid-glass";
const boardVariant: BoardVariant = VALID_VARIANTS.includes(requested as BoardVariant)
  ? (requested as BoardVariant)
  : "liquid-glass";
---

<RootLayout
  title="4thewin — Connect 4, but smarter"
  description="Play Connect 4 against an AI in your browser. No signup needed to start."
>
  <main
    id="main"
    class="relative mx-auto flex w-full max-w-7xl flex-col px-margin-mobile pt-28 pb-8 md:h-full md:overflow-hidden md:px-margin-desktop md:pt-28 md:pb-4"
  >
    {/* Hero — absolutely positioned over the entire main content area.
        Two-line treatment with hierarchy: a small muted "connect 4," kicker
        over a big foreground "but smarter." statement. Lowercase italic
        Fraunces throughout — literary register. The size + color contrast
        carries the visual weight, NOT just a line break. */}
    <h1
      id="hero-pitch"
      class="hero-draw absolute top-28 right-0 bottom-0 left-0 z-10 grid place-items-center px-margin-mobile text-center md:px-margin-desktop"
    >
      <span class="font-display font-light italic leading-tight tracking-tight">
        <span class="block text-lg text-muted-foreground md:text-xl lg:text-2xl">
          connect 4,
        </span>
        <span class="block text-5xl text-foreground md:text-7xl lg:text-display">
          but smarter.
        </span>
      </span>
    </h1>

    {/* Kicker — small game-state label above the grid. Reveals after the
        hero exits, in its original (pre-intro-redesign) position. */}
    <div
      class="page-reveal mb-6 flex justify-center md:mb-8"
      style="--reveal-delay: 2.5s"
    >
      <Headline state="your-turn" />
    </div>

    {/* Game grid — board centered in the remaining vertical space, side
        panels flanking on desktop. Reveals after the kicker. */}
    <div class="grid grid-cols-1 gap-10 md:flex-1 md:grid-cols-12 md:items-center md:gap-gutter">

      {/* AITelemetry — desktop left, mobile after the board */}
      <div
        class="page-reveal order-2 flex justify-center md:order-1 md:col-span-3"
        style="--reveal-delay: 2.9s"
      >
        <AITelemetry />
      </div>

      {/* Board */}
      <div
        class="page-reveal order-1 flex justify-center md:order-2 md:col-span-6"
        style="--reveal-delay: 2.7s"
      >
        <Board variant={boardVariant} />
      </div>

      {/* Leaderboard — desktop right, mobile last */}
      <div
        class="page-reveal order-3 flex justify-center md:order-3 md:col-span-3"
        style="--reveal-delay: 2.9s"
      >
        <Leaderboard />
      </div>

    </div>
  </main>

  {/* SVG filter for the liquid-glass board variant.
      Defines the lg-dist filter referenced by `.lg-filter` in globals.css.
      feTurbulence generates fractal noise; feDisplacementMap warps the
      backdrop using the noise as a displacement map → refraction effect.
      Browser support: works in Chromium (Chrome/Edge); falls back to a
      plain frosted blur in Safari/Firefox where backdrop-filter + SVG
      filter URL isn't supported. */}
  <svg aria-hidden="true" style="position:absolute;width:0;height:0;pointer-events:none;">
    <defs>
      <filter id="lg-dist" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence type="fractalNoise" baseFrequency="0.008 0.008" numOctaves="2" seed="92" result="noise" />
        <feGaussianBlur in="noise" stdDeviation="2" result="blurred" />
        <feDisplacementMap in="SourceGraphic" in2="blurred" scale="70" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>
</RootLayout>
