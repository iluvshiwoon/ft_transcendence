---
import RootLayout from "~/layouts/RootLayout.astro";

const lastUpdated = "Mai 2026";

const sections = [
  {
    title: "Votre compte",
    body: `Vous êtes responsable de la sécurité de vos identifiants et de l'activité sur votre compte. Choisissez un pseudo qui n'est ni offensant ni une usurpation d'identité — nous pouvons supprimer les comptes qui abusent de cette règle.`,
  },
  {
    title: "Utilisation acceptable",
    body: `Ne harcelez pas, ne menacez pas, ne spammez pas les autres joueurs. Ne trichez pas, n'exploitez pas de bugs, ne perturbez pas les parties. Ne tentez pas de casser, surcharger ou attaquer la plateforme. N'uploadez pas de contenu illégal ou offensant en avatar.`,
  },
  {
    title: "Contenu uploadé",
    body: `Vous conservez la propriété de ce que vous uploadez (avatar, bio). En l'uploadant, vous nous autorisez à l'afficher au sein de la plateforme dans le cadre d'une utilisation normale. Vous êtes responsable d'avoir le droit d'utiliser tout contenu que vous uploadez.`,
  },
  {
    title: "Disponibilité",
    body: `Le service est fourni « tel quel ». En tant que projet scolaire, il peut tomber en panne, perdre des données ou changer à tout moment sans préavis. Ne comptez pas dessus pour quoi que ce soit d'important.`,
  },
  {
    title: "Résiliation",
    body: `Vous pouvez supprimer votre compte à tout moment depuis vos paramètres. Nous pouvons suspendre les comptes qui enfreignent ces conditions.`,
  },
];
---

<RootLayout title="4thewin — Conditions d'utilisation" description="Les règles d'utilisation de 4thewin.">
  <main
    id="main"
    class="mx-auto w-full max-w-3xl flex-1 px-margin-mobile pt-[120px] pb-20 md:pt-[150px]"
  >
    <header class="page-reveal flex flex-col gap-4" style="--reveal-delay: 0.1s">
      <span class="font-mono text-mono-sm uppercase text-accent">Légal</span>
      <h1 class="font-display text-5xl font-semibold tracking-tight text-foreground md:text-6xl">
        Conditions <span class="italic font-light">d'utilisation</span>
      </h1>
      <p class="font-mono text-mono-sm uppercase text-muted-foreground">
        Dernière mise à jour · {lastUpdated}
      </p>
    </header>

    <p class="page-reveal mt-8 font-display text-xl font-light italic leading-relaxed text-foreground/70" style="--reveal-delay: 0.25s">
      Un projet gratuit et non-commercial — pas de garantie, pas d'abonnement, pas de petites lignes.
    </p>

    <hr class="page-reveal mt-10 border-t border-border" style="--reveal-delay: 0.35s" />

    <div class="mt-10 flex flex-col">
      {sections.map((s, i) => (
        <section
          class="page-reveal grid gap-3 border-t border-border/60 py-8 first:border-t-0 md:grid-cols-[3rem_1fr] md:gap-8"
          style={`--reveal-delay: ${0.4 + i * 0.1}s`}
        >
          <span class="font-mono text-mono-md text-accent md:pt-1">
            {String(i + 1).padStart(2, "0")}
          </span>
          <div class="flex flex-col gap-3">
            <h2 class="font-display text-2xl font-semibold tracking-tight text-foreground">
              {s.title}
            </h2>
            <p class="leading-relaxed text-foreground/80">{s.body}</p>
          </div>
        </section>
      ))}
    </div>

    <div class="page-reveal mt-12 flex justify-center" style="--reveal-delay: 1s">
      <a
        href="/"
        class="font-mono text-mono-md uppercase text-muted-foreground underline underline-offset-4 decoration-transparent transition-colors duration-75 hover:text-accent hover:decoration-accent"
      >
        ← Retour à l'accueil
      </a>
    </div>
  </main>
</RootLayout>