---
/**
 * /privacy — Privacy Policy.
 *
 * Static prose page. Required by the 42 subject. Content describes what data
 * the platform collects (account info, game stats) and how it's handled.
 *
 * Layout note: RootLayout's body is `md:overflow-hidden` (single-screen pages
 * like the landing). Prose pages can exceed the viewport, so <main> takes
 * `flex-1 overflow-y-auto` to scroll its own content on desktop.
 */
import RootLayout from "~/layouts/RootLayout.astro";

const lastUpdated = "May 2026";
---

<RootLayout title="4thewin — Privacy Policy" description="How 4thewin handles your data.">
  <main
    id="main"
    class="mx-auto w-full max-w-3xl flex-1 overflow-y-auto px-margin-mobile pt-[126px] pb-16 md:pt-[140px]"
  >
    <header class="flex flex-col gap-3">
      <h1 class="font-display text-4xl font-bold tracking-tight text-foreground md:text-5xl">
        Privacy Policy
      </h1>
      <p class="font-mono text-mono-sm uppercase text-muted-foreground">
        Last updated · {lastUpdated}
      </p>
    </header>

    <div class="mt-12 flex flex-col gap-10">
      <section class="flex flex-col gap-3">
        <p class="leading-relaxed text-foreground/80">
          4thewin is a student project built for the 42 school curriculum. This
          page explains what data we collect, why, and what you can do about it.
          We keep it short because we keep the data minimal.
        </p>
      </section>

      <section class="flex flex-col gap-3">
        <h2 class="font-display text-xl font-semibold text-foreground">Data we collect</h2>
        <ul class="flex flex-col gap-2 text-foreground/80">
          <li class="leading-relaxed">
            <span class="font-semibold text-foreground">Account info</span> — your
            email, username, and (if you sign up with a password) a securely
            hashed password. We never store passwords in clear text.
          </li>
          <li class="leading-relaxed">
            <span class="font-semibold text-foreground">Profile</span> — optional
            bio, avatar image, and your chosen game skins.
          </li>
          <li class="leading-relaxed">
            <span class="font-semibold text-foreground">Game data</span> — your
            match history, results, and statistics (games played, won, lost).
          </li>
          <li class="leading-relaxed">
            <span class="font-semibold text-foreground">42 OAuth</span> — if you
            sign in with your 42 account, we receive your 42 login, email, and
            avatar from 42's API. We do not access anything else.
          </li>
        </ul>
      </section>

      <section class="flex flex-col gap-3">
        <h2 class="font-display text-xl font-semibold text-foreground">How we use it</h2>
        <p class="leading-relaxed text-foreground/80">
          Your data is used solely to run the platform: authenticate you,
          display your profile to other players, match you in games, deliver
          chat messages, and compute your statistics. We do not sell your data,
          run ads, or share it with third parties.
        </p>
      </section>

      <section class="flex flex-col gap-3">
        <h2 class="font-display text-xl font-semibold text-foreground">Security</h2>
        <p class="leading-relaxed text-foreground/80">
          Passwords are hashed with bcrypt. Sessions use signed tokens stored in
          HttpOnly cookies (inaccessible to client-side scripts). Secrets are
          managed through HashiCorp Vault, and traffic passes through a web
          application firewall (ModSecurity).
        </p>
      </section>

      <section class="flex flex-col gap-3">
        <h2 class="font-display text-xl font-semibold text-foreground">Your rights</h2>
        <p class="leading-relaxed text-foreground/80">
          You can edit your profile information at any time. You can delete your
          account from your settings — when you do, your personal data is
          anonymized (your username becomes "Joueur supprimé") while past games
          remain in other players' history for integrity.
        </p>
      </section>

      <section class="flex flex-col gap-3">
        <h2 class="font-display text-xl font-semibold text-foreground">Contact</h2>
        <p class="leading-relaxed text-foreground/80">
          This is a non-commercial school project. For any question about your
          data, reach out to the project team through the school.
        </p>
      </section>
    </div>
  </main>
</RootLayout>
