---
/**
 * /play — main lobby / dashboard for authenticated users.
 *
 * Anonymous (signed-out) users play on the landing page, where the demo
 * loop runs against the AI with a server-authoritative anonymous session.
 * /play is the post-signup destination — multiplayer, friends, lobbies,
 * stats — and requires an account.
 *
 * Access control: unauthenticated requests redirect to /signup?step=1.
 * Returning users can navigate from there to the (future) /login page.
 *
 * Currently a stub. Will be filled in once Tim's lobby module + friends
 * features ship.
 */
import RootLayout from "~/layouts/RootLayout.astro";
import { isAuthenticated } from "~/lib/auth";

if (!(await isAuthenticated(Astro))) {
  return Astro.redirect("/signup?step=1");
}
---

<RootLayout title="4thewin — Play" description="Play page (under construction).">
  <main
    id="main"
    class="mx-auto flex w-full max-w-3xl flex-col items-center justify-center gap-3 px-margin-mobile pt-32 pb-12 md:px-margin-desktop"
  >
    <p class="font-mono text-mono-sm uppercase text-muted-foreground">Play</p>
    <h1 class="font-display italic font-light tracking-wide text-3xl md:text-4xl text-foreground leading-none">
      Coming soon
    </h1>
  </main>
</RootLayout>
