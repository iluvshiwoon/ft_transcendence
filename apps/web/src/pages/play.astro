---
/**
 * /play — lobby (authed home).
 *
 * The user lands here after sign-in. Primary action is "play a game now",
 * with a secondary surface for resuming in-progress games.
 *
 * Visual language matches /profile: cardCls surfaces, font-display italic
 * for emotional headers, font-mono uppercase for HUD labels, pawn-yellow /
 * pawn-red dots for game outcomes.
 *
 * v1 sections (this file): Quick Play CTAs + Resume strip. Deferred: any
 * lobby-only surface that earns its place (public lobbies, daily challenge,
 * activity ticker). Friends online + Recent results were tried and removed
 * because they were just slim mirrors of /profile — see HANDOFF_BACKEND.md
 * for the v2 surfaces.
 *
 * Auth: gated behind isAuthenticated(). Unauthed visitors get bounced
 * to /signup?step=1, which already has a "Sign in" link for users with
 * existing accounts. Backed by §3.4 in HANDOFF_BACKEND.md now that
 * /me and friends endpoints are wired.
 */
import RootLayout from "~/layouts/RootLayout.astro";
import { buttonVariants } from "~/components/ui/button";
import { cn } from "~/lib/utils";
import { isAuthenticated } from "~/lib/auth";
import { ChallengeSearchModal } from "~/components/landing/ChallengeSearchModal";

if (!(await isAuthenticated(Astro))) {
  return Astro.redirect("/signup?step=1");
}

type Difficulty = "easy" | "medium" | "hard";
type TimeControl = { id: "bullet" | "blitz" | "daily"; label: string; duration: string; seconds: 180 | 600 | 3600 };

const DIFFICULTIES: { id: Difficulty; label: string }[] = [
  { id: "easy",   label: "Easy"   },
  { id: "medium", label: "Medium" },
  { id: "hard",   label: "Hard"   },
];

const TIME_CONTROLS: TimeControl[] = [
  { id: "bullet", label: "Bullet", duration: "3 min",  seconds: 180  },
  { id: "blitz",  label: "Blitz",  duration: "10 min", seconds: 600  },
  { id: "daily",  label: "Daily",  duration: "60 min", seconds: 3600 },
];

// Defaults — when a settings page lands these'll come from the user's prefs.
const defaultDifficulty: Difficulty = "medium";
const defaultTimeControl = "blitz";

import { ResumeStrip } from "~/components/landing/ResumeStrip";

// ─── Future lobby-only surfaces (intentionally omitted from v1) ─────────────
// Friends online and Recent games used to live here as side-by-side cards
// but they were just slim mirrors of /profile (Friends tab + Overview tab),
// not lobby-specific value. Replaced by upcoming surfaces that *only* the
// lobby would carry — see HANDOFF_BACKEND.md for the spec:
//   - Public lobbies "Quick join" feed (uses Tim's GET /api/lobbies)
//   - Daily challenge / weekly missions
//   - Live activity ticker (recent finishes by friends, etc.)
// Add them back as standalone sections only when the backend that earns
// their place is ready.

// Shared card style (same as /profile).
const cardCls = "rounded-xl border border-border bg-surface text-surface-foreground";
---

<RootLayout
  title="4thewin — Play"
  description="Quick game vs the AI, or challenge a friend."
>
  <main
    id="main"
    class="mx-auto w-full max-w-7xl px-margin-mobile pt-28 pb-16 md:px-margin-desktop md:pt-32"
  >
    {/* =========================================================
        QUICK PLAY CTAs — the hero of the lobby.
        Two cards, equal weight. Card structure (matches the Stats
        time-control cards in /profile):
          - mono uppercase header (functional voice, not display italic
            — same language as BULLET / BLITZ / DAILY)
          - optional one-line font-sans subtitle
          - inline controls (pills) — varies per card
          - primary CTA pinned to the bottom via mt-auto so both cards
            share an identical vertical skeleton even when their
            middle-content differs
        ========================================================= */}
    <section
      aria-label="Quick play"
      class="page-reveal grid grid-cols-1 gap-x-gutter gap-y-gutter md:grid-cols-2 md:grid-rows-[repeat(4,auto)] md:gap-y-5 overflow-visible relative z-10"
      style="--reveal-delay: 0s"
      data-quickplay
    >
      {/* ── Play AI card ─────────────────────────────────────── */}
      <article class={cn(cardCls, "flex flex-col gap-5 p-5 md:row-span-4 md:grid md:grid-rows-subgrid")}>
        <header class="flex items-baseline justify-between gap-3">
          <p class="font-mono text-mono-md uppercase text-foreground">
            Vs AI
          </p>
          <p class="font-mono text-mono-sm uppercase text-muted-foreground">
            Quick
          </p>
        </header>

        {/* Row 2 — Difficulty */}
        <div>
          <p class="font-mono text-mono-sm uppercase text-muted-foreground">Difficulty</p>
          <ul role="radiogroup" aria-label="AI difficulty" data-pills="ai-difficulty" class="mt-2 flex flex-wrap gap-2">
            {DIFFICULTIES.map((d) => (
              <li>
                <button
                  type="button"
                  role="radio"
                  aria-checked={d.id === defaultDifficulty ? "true" : "false"}
                  data-value={d.id}
                  class:list={[
                    "px-3 py-1 rounded-full font-mono text-mono-sm uppercase",
                    "border border-border bg-muted text-muted-foreground",
                    "transition-colors",
                    "hover:border-foreground hover:bg-foreground/20 hover:text-foreground",
                    "aria-checked:border-foreground aria-checked:bg-foreground aria-checked:text-background",
                    "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground",
                  ]}
                >
                  {d.label}
                </button>
              </li>
            ))}
          </ul>
        </div>

        {/* Row 3 — Time control */}
        <div>
          <p class="font-mono text-mono-sm uppercase text-muted-foreground">Time control</p>
          <ul role="radiogroup" aria-label="Time control" data-pills="ai-time" class="mt-2 flex flex-wrap gap-2">
            {TIME_CONTROLS.map((tc) => (
              <li>
                <button
                  type="button"
                  role="radio"
                  aria-checked={tc.id === defaultTimeControl ? "true" : "false"}
                  data-value={tc.id}
                  data-seconds={tc.seconds}
                  class:list={[
                    "px-3 py-1 rounded-full font-mono text-mono-sm uppercase tabular-nums",
                    "border border-border bg-muted text-muted-foreground",
                    "transition-colors",
                    "hover:border-foreground hover:bg-foreground/20 hover:text-foreground",
                    "aria-checked:border-foreground aria-checked:bg-foreground aria-checked:text-background",
                    "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground",
                  ]}
                >
                  {tc.duration}
                </button>
              </li>
            ))}
          </ul>
        </div>

        {/* Row 4 — CTA */}
        <button
          type="button"
          data-play-ai-start
          class={cn(buttonVariants({ variant: "brand-filled", size: "pill" }), "self-end w-full justify-center gap-1.5 cursor-pointer")}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true">
            <path d="M5 3l14 9-14 9V3z" />
          </svg>
          Start game
        </button>
      </article>

      {/* ── Challenge card ───────────────────────────────────── */}
      <article class={cn(cardCls, "flex flex-col gap-5 p-5 overflow-visible z-10 md:row-span-4 md:grid md:grid-rows-subgrid")}>
        <header class="flex items-baseline justify-between gap-3">
          <p class="font-mono text-mono-md uppercase text-foreground">
            Vs a friend
          </p>
          <p class="font-mono text-mono-sm uppercase text-muted-foreground">
            Multiplayer
          </p>
        </header>

        {/* Row 2 — Description (aligns with AI card's Difficulty row) */}
        <p class="font-sans text-sm text-muted-foreground">
          Search for a friend and send them a challenge directly in chat.
        </p>

        {/* Row 3 — Time control (aligns with AI card's Time control row) */}
        <div>
          <p class="font-mono text-mono-sm uppercase text-muted-foreground">Time control</p>
          <ul role="radiogroup" aria-label="Time control" data-pills="multi-time" class="mt-2 flex flex-wrap gap-2">
            {TIME_CONTROLS.map((tc) => (
              <li>
                <button
                  type="button"
                  role="radio"
                  aria-checked={tc.id === defaultTimeControl ? "true" : "false"}
                  data-value={tc.id}
                  data-seconds={tc.seconds}
                  class:list={[
                    "px-3 py-1 rounded-full font-mono text-mono-sm uppercase tabular-nums",
                    "border border-border bg-muted text-muted-foreground",
                    "transition-colors",
                    "hover:border-foreground hover:bg-foreground/20 hover:text-foreground",
                    "aria-checked:border-foreground aria-checked:bg-foreground aria-checked:text-background",
                    "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground",
                  ]}
                >
                  {tc.duration}
                </button>
              </li>
            ))}
          </ul>
        </div>

        {/* Row 4 — CTA + dropdown */}
        <div class="relative self-end w-full">
          <button
            type="button"
            id="open-challenge-modal-btn"
            class={cn(buttonVariants({ variant: "brand-filled", size: "pill" }), "w-full justify-center gap-1.5 cursor-pointer")}
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
              <line x1="19" y1="8" x2="19" y2="14" />
              <line x1="22" y1="11" x2="16" y2="11" />
            </svg>
            Challenge a friend
          </button>

          {/* Challenge friend search dropdown (React island) */}
          <ChallengeSearchModal client:only="react" />
        </div>
      </article>
    </section>

    {/* =========================================================
        RESUME STRIP — list of active games.
        ========================================================= */}
    <ResumeStrip client:load />
  </main>

  {/* =========================================================
      Inline behaviour — radio-pill state for the AI card.
      Tiny vanilla JS, no React island. The pills toggle aria-checked
      on click; CSS attribute selectors handle the visual change.
      Phase 2 will read these data-value attributes when wiring the
      Start button to POST /api/games/ai.
      ========================================================= */}
  <script>
    function wirePillGroup(group: HTMLElement) {
      const pills = Array.from(group.querySelectorAll<HTMLButtonElement>("[role='radio']"));
      pills.forEach((pill) => {
        pill.addEventListener("click", () => {
          pills.forEach((p) => p.setAttribute("aria-checked", p === pill ? "true" : "false"));
        });
      });
    }

    document.querySelectorAll<HTMLElement>("[data-pills]").forEach(wirePillGroup);

    // Wire the challenge-a-friend button → dispatch event to the React modal island
    const challengeBtn = document.getElementById("open-challenge-modal-btn");
    if (challengeBtn) {
      challengeBtn.addEventListener("click", () => {
        const activeTimeBtn = document.querySelector<HTMLButtonElement>("[data-pills='multi-time'] [aria-checked='true']");
        const seconds = parseInt(activeTimeBtn?.getAttribute("data-seconds") || "600", 10);
        window.dispatchEvent(new CustomEvent("challenge-modal:open", { detail: { time: seconds } }));
      });
    }

    // AI Game creation handler
    const startAiButton = document.querySelector<HTMLButtonElement>("[data-play-ai-start]");
    if (startAiButton) {
      startAiButton.addEventListener("click", async () => {
        startAiButton.disabled = true;
        const originalContent = startAiButton.innerHTML;
        startAiButton.textContent = "Creating game...";

        try {
          const activeDiffButton = document.querySelector<HTMLButtonElement>("[data-pills='ai-difficulty'] [aria-checked='true']");
          const difficulty = activeDiffButton?.getAttribute("data-value") || "medium";

          const activeTimeButton = document.querySelector<HTMLButtonElement>("[data-pills='ai-time'] [aria-checked='true']");
          const seconds = parseInt(activeTimeButton?.getAttribute("data-seconds") || "600", 10);

          const response = await fetch("/api/games/ai", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              difficulty,
              timePerPlayerSeconds: seconds,
            }),
          });

          if (!response.ok) {
            const err = await response.json();
            throw new Error(err.error || "Failed to create game");
          }

          const data = await response.json();
          window.location.href = `/play/ai/${data.gameId}`;
        } catch (error) {
          alert(error instanceof Error ? error.message : "An error occurred starting the game.");
          startAiButton.disabled = false;
          startAiButton.innerHTML = originalContent;
        }
      });
    }
  </script>
</RootLayout>
