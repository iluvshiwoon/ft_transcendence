---
/**
 * /play/m/[id] — multiplayer game page (authed).
 *
 * Same 3-col grid as /play/ai/[id] but the left column is a real-time
 * chat panel with the opponent instead of AITelemetry. The right column
 * shows the opponent card + game controls (no AI-specific form/streak).
 *
 * Chat panel:
 *   - Header: opponent avatar + username + status dot
 *   - Message list (mock, scrollable)
 *   - Input row: text field + send button
 *   - Inline JS handles local send (appends to the list) — real wiring
 *     uses socket.io chat events once Tim's game socket lands.
 *
 * Board: liquid-glass variant, same as vs-AI.
 * Auth: gated behind isAuthenticated() (matches /play/ai/[id]).
 */
import RootLayout from "~/layouts/RootLayout.astro";
import { Board } from "~/components/landing/Board";
import { EndGameOverlay } from "~/components/landing/EndGameOverlay";
import { buttonVariants } from "~/components/ui/button";
import { isAuthenticated } from "~/lib/auth";
import { cn } from "~/lib/utils";

const { id: _gameId } = Astro.params;

if (!(await isAuthenticated(Astro))) {
  return Astro.redirect("/signup?step=1");
}
const authed = true;

// Fetch user profile SSR-side to get the user's customized skin preferences.
const backendUrl = process.env.BACKEND_URL ?? "http://localhost:3000";
const authToken = Astro.cookies.get("auth_token")?.value;
let gridSkin = "liquid-glass"; // fallback default
if (authToken) {
  try {
    const res = await fetch(`${backendUrl}/api/profile`, {
      headers: { Cookie: `auth_token=${authToken}` },
      signal: AbortSignal.timeout(1500),
    });
    if (res.ok) {
      const profile = await res.json();
      gridSkin = profile.gridSkin;
    }
  } catch (e) {
    // fallback silently
  }
}

// ─── Mock data ───────────────────────────────────────────────────────────────

const opponent = {
  username: "Sarah_w",
  initial:  "S",
  rating:   2710,
  status:   "online" as "online" | "in_game" | "offline",
};

interface ChatMessage {
  id: number;
  from: "me" | "opponent";
  text: string;
  time: string;
}
const messages: ChatMessage[] = [
  { id: 1, from: "opponent", text: "glhf!",                    time: "14:02" },
  { id: 2, from: "me",       text: "you too 🙂",               time: "14:02" },
  { id: 3, from: "opponent", text: "nice move",                time: "14:04" },
  { id: 4, from: "me",       text: "thanks, didn't see that coming", time: "14:05" },
];

const cardCls = "rounded-xl border border-border bg-surface text-surface-foreground";
---

<RootLayout
  title="Game vs Sarah_w — 4thewin"
  description="Connect 4 multiplayer"
>
  <main
    id="main"
    class="relative mx-auto flex w-full max-w-7xl flex-col px-margin-mobile pt-28 pb-8 md:h-full md:overflow-hidden md:px-margin-desktop md:pt-28 md:pb-4"
  >
    <div class="grid grid-cols-1 gap-16 md:flex-1 md:grid-cols-12 md:items-center md:gap-gutter">

      {/* ── Left column: Chat panel ─────────────────────────────────────── */}
      <div
        class="page-reveal order-2 flex justify-center md:order-1 md:col-span-3"
        style="--reveal-delay: 0s"
      >
        <div class={cn(cardCls, "flex w-full max-w-[220px] flex-col gap-3 p-4")}>

          {/* Opponent header */}
          <div class="flex items-center gap-2.5">
            <span
              aria-hidden="true"
              class="flex size-9 shrink-0 items-center justify-center rounded-md border border-border bg-foreground font-display italic text-base text-background"
            >
              {opponent.initial}
            </span>
            <div class="flex min-w-0 flex-col">
              <span class="truncate font-sans text-sm font-semibold text-foreground">
                {opponent.username}
              </span>
              <span class="flex items-center gap-1.5 font-mono text-mono-sm uppercase text-muted-foreground">
                <span aria-hidden="true" class="size-2 rounded-full bg-pawn-yellow" />
                Online · {opponent.rating}
              </span>
            </div>
          </div>

          {/* Message list */}
          <ol
            id="chat-messages"
            aria-label="Chat messages"
            aria-live="polite"
            class="flex max-h-64 flex-col gap-2 overflow-y-auto pr-1"
          >
            {messages.map((m) => (
              <li
                class:list={[
                  "flex flex-col gap-0.5",
                  m.from === "me" ? "items-end" : "items-start",
                ]}
              >
                <span
                  class:list={[
                    "max-w-[90%] rounded-xl px-3 py-1.5 font-sans text-sm",
                    m.from === "me"
                      ? "bg-foreground text-background rounded-br-sm"
                      : "bg-muted text-foreground rounded-bl-sm",
                  ]}
                >
                  {m.text}
                </span>
                <span class="font-mono text-mono-sm uppercase text-muted-foreground">
                  {m.time}
                </span>
              </li>
            ))}
          </ol>

          {/* Input row */}
          <form
            id="chat-form"
            class="flex items-center gap-2"
            onsubmit="return false"
          >
            <input
              id="chat-input"
              type="text"
              placeholder="Message…"
              autocomplete="off"
              maxlength="200"
              class="min-w-0 flex-1 rounded-full border border-border bg-muted px-3 py-1.5 font-sans text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-foreground"
            />
            <button
              type="submit"
              aria-label="Send"
              class="grid size-8 shrink-0 place-items-center rounded-full bg-foreground text-background hover:bg-foreground/80 active:scale-[0.96] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true">
                <line x1="22" y1="2" x2="11" y2="13" />
                <polygon points="22 2 15 22 11 13 2 9 22 2" />
              </svg>
            </button>
          </form>

        </div>
      </div>

      {/* ── Center column: Board ─────────────────────────────────────────── */}
      <div class="order-1 flex flex-col items-center gap-8 md:order-2 md:col-span-6 md:gap-0 md:relative">
        <div
          class="page-reveal relative"
          style="--reveal-delay: 0.2s"
        >
          <Board variant={gridSkin as any} client:load />
          <EndGameOverlay authed={authed} client:load />
        </div>
      </div>

      {/* ── Right column: Opponent card + controls ───────────────────────
          Exact same structure as /play/ai/[id] right column. */}
      <div
        class="page-reveal order-3 flex justify-center md:order-3 md:col-span-3 md:justify-start md:pl-gutter"
        style="--reveal-delay: 0s"
      >
        <div class="relative flex w-full max-w-[220px] flex-col items-center gap-6 text-center font-mono text-mono-sm text-muted-foreground md:pl-6 md:before:absolute md:before:left-0 md:before:top-1/2 md:before:h-2/3 md:before:w-px md:before:-translate-y-1/2 md:before:bg-border md:before:content-['']">

          {/* Opponent info */}
          <div>
            <p class="font-mono text-mono-md uppercase text-foreground">
              {opponent.username}
            </p>
            <p class="mt-1 font-mono text-mono-sm uppercase text-muted-foreground tabular-nums">
              Rating {opponent.rating}
            </p>
          </div>

          {/* Controls */}
          <div class="flex flex-col items-center gap-3 pt-1">
            <a
              href="/play"
              data-todo-integration="POST /api/lobbies — Tim's endpoint, exists post-rebase"
              class="inline-flex items-center gap-1.5 rounded-full bg-muted px-4 py-1.5 font-mono text-mono-sm uppercase text-muted-foreground hover:bg-foreground hover:text-background active:scale-[0.98] focus-visible:outline-none focus-visible:bg-foreground focus-visible:text-background"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true">
                <polyline points="1 4 1 10 7 10" />
                <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10" />
              </svg>
              New game
            </a>
            <a
              href="/play"
              data-todo-integration="socket: game:surrender — Tim's socket, exists post-rebase"
              class="inline-flex items-center gap-1.5 rounded-full bg-muted px-4 py-1.5 font-mono text-mono-sm uppercase text-muted-foreground hover:bg-foreground hover:text-background active:scale-[0.98] focus-visible:outline-none focus-visible:bg-foreground focus-visible:text-background"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true">
                <line x1="4" y1="22" x2="4" y2="15" />
                <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z" />
              </svg>
              Resign
            </a>
          </div>

        </div>
      </div>

    </div>
  </main>

  {/* SVG filter for liquid-glass board variant */}
  <svg aria-hidden="true" style="position:absolute;width:0;height:0;pointer-events:none;">
    <defs>
      <filter id="lg-dist" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence type="fractalNoise" baseFrequency="0.008 0.008" numOctaves="2" seed="92" result="noise" />
        <feGaussianBlur in="noise" stdDeviation="2" result="blurred" />
        <feDisplacementMap in="SourceGraphic" in2="blurred" scale="70" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>

  {/* Chat — local-only send for v1. Real wiring uses socket.io
      chat events once Tim's game socket lands. */}
  <script>
    const form = document.getElementById("chat-form") as HTMLFormElement | null;
    const input = document.getElementById("chat-input") as HTMLInputElement | null;
    const list  = document.getElementById("chat-messages") as HTMLOListElement | null;

    if (form && input && list) {
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const text = input.value.trim();
        if (!text) return;

        const now = new Date();
        const time = `${now.getHours().toString().padStart(2, "0")}:${now.getMinutes().toString().padStart(2, "0")}`;

        const li = document.createElement("li");
        li.className = "flex flex-col gap-0.5 items-end";
        li.innerHTML = `
          <span class="max-w-[90%] rounded-xl rounded-br-sm bg-foreground px-3 py-1.5 font-sans text-sm text-background">${text.replace(/</g, "&lt;")}</span>
          <span class="font-mono text-mono-sm uppercase text-muted-foreground">${time}</span>
        `;
        list.appendChild(li);
        list.scrollTop = list.scrollHeight;
        input.value = "";
      });
    }
  </script>
</RootLayout>
