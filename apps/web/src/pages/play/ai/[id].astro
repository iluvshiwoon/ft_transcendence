---
/**
 * /play/ai/[id] — vs-AI game page (authed).
 *
 * Reuses the gameplay composition from the landing page (Board +
 * AITelemetry + EndGameOverlay) but swaps the marketing Leaderboard
 * on the right for a gameplay-focused tool stack:
 *   - AI opponent card (difficulty + your form last 5 + current streak)
 *   - Move history (compact column-by-column log)
 *   - Game controls (New game, Resign)
 *
 * Layout matches landing's 3-col grid so the board reads as the
 * focal point with AITelemetry on the left and the right tool stack
 * flanking it. No hero text, no marketing CTAs — this is a tool
 * surface for in-game use.
 *
 * Auth: matches /play and /profile — no redirect for now while data
 * is mocked. TODO: gate behind isAuthenticated() once real games
 * land. The :id parameter is the game ID returned by POST
 * /api/games/ai (Tim's endpoint, exists post-rebase).
 *
 * Board variant: 'liquid-glass' to match the landing page exactly.
 * The lg-dist SVG filter has to live on every page that uses this
 * variant (referenced via filter URL).
 */
import RootLayout from "~/layouts/RootLayout.astro";
import { Board } from "~/components/landing/Board";
import { EndGameOverlay } from "~/components/landing/EndGameOverlay";
import { AITelemetry } from "~/components/landing/AITelemetry";
import { buttonVariants } from "~/components/ui/button";
import { isAuthenticated } from "~/lib/auth";
import { cn } from "~/lib/utils";

const { id: _gameId } = Astro.params;
const authed = await isAuthenticated(Astro);

// ─── Right-column mock data ─────────────────────────────────────────────────
// All replaced once backend lands. Game id + state will come from GET
// /api/games/:id (Tim, exists). Form / streak come from §3.2 (Elo) +
// §3.3 (history) once those ship — we'll filter the history endpoint
// by aiDifficulty match.

type Difficulty = "easy" | "medium" | "hard";
type GameResult = "win" | "loss" | "draw";

interface AiOpponentMock {
  difficulty: Difficulty;
  formLast5: GameResult[];               // oldest → newest
  currentStreak: number;
  longestStreak: number;
  totalGames: number;
}
const aiOpponent: AiOpponentMock = {
  difficulty: "medium",
  formLast5: ["win", "win", "loss", "win", "win"],
  currentStreak: 3,
  longestStreak: 7,
  totalGames: 28,
};

interface MoveRow {
  num: number;
  player: "you" | "ai";
  column: number;                        // 1..7
}
const moves: MoveRow[] = [
  { num: 1, player: "you", column: 4 },
  { num: 1, player: "ai",  column: 3 },
  { num: 2, player: "you", column: 4 },
  { num: 2, player: "ai",  column: 5 },
  { num: 3, player: "you", column: 2 },
  { num: 3, player: "ai",  column: 1 },
  { num: 4, player: "you", column: 3 },
];

const resultDot: Record<GameResult, string> = {
  win:  "bg-pawn-yellow",
  loss: "bg-pawn-red",
  draw: "bg-muted-foreground",
};

const cardCls = "rounded-xl border border-border bg-surface text-surface-foreground";
---

<RootLayout
  title="Game vs AI — 4thewin"
  description="Connect 4 vs AI"
>
  <main
    id="main"
    class="relative mx-auto flex w-full max-w-7xl flex-col px-margin-mobile pt-28 pb-8 md:h-full md:overflow-hidden md:px-margin-desktop md:pt-28 md:pb-4"
  >
    {/* 3-col grid mirrors landing: AITelemetry / Board / right-stack.
        items-center anchors all three columns around the board's
        vertical centre. Mobile collapses to one column with the board
        first (order-1), AITelemetry second, right stack last. */}
    <div class="grid grid-cols-1 gap-16 md:flex-1 md:grid-cols-12 md:items-center md:gap-gutter">

      {/* AITelemetry — desktop left, mobile after the board */}
      <div
        class="page-reveal order-2 flex justify-center md:order-1 md:col-span-3"
        style="--reveal-delay: 0s"
      >
        <AITelemetry client:load />
      </div>

      {/* Board — center column. EndGameOverlay shares the same relative
          wrapper so when the game ends the card overlays the board
          exactly. authed prop drives the CTA — 'Play again' / 'Back to
          lobby' for authed users (always us on this page). */}
      <div class="order-1 flex flex-col items-center gap-8 md:order-2 md:col-span-6 md:gap-0 md:relative">
        <div
          class="page-reveal relative"
          style="--reveal-delay: 0.2s"
        >
          <Board variant="liquid-glass" client:load />
          <EndGameOverlay authed={authed} client:load />
        </div>
      </div>

      {/* Right column — gameplay tool stack. Three small cards stacked,
          max-w to keep the column from over-stretching at wide viewports.
          AI opponent card is the most visually weighted (largest content)
          to balance the AITelemetry on the left. */}
      <div
        class="page-reveal order-3 flex justify-center md:order-3 md:col-span-3"
        style="--reveal-delay: 0s"
      >
        <div class="flex w-full max-w-[280px] flex-col gap-4">

          {/* ── AI opponent card ───────────────────────────── */}
          <article class={cn(cardCls, "p-4")}>
            <header class="flex items-baseline justify-between gap-3">
              <p class="font-mono text-mono-md uppercase text-foreground">
                AI · {aiOpponent.difficulty}
              </p>
              <p class="font-mono text-mono-sm uppercase text-muted-foreground tabular-nums">
                {aiOpponent.totalGames} games
              </p>
            </header>

            {/* Form (last 5) — pawn-color dots, oldest → newest */}
            <div class="mt-4">
              <p class="font-mono text-mono-sm uppercase text-muted-foreground">
                Form · last 5
              </p>
              <ol class="mt-2 flex items-center gap-2" aria-label={`Last 5 results vs AI ${aiOpponent.difficulty}`}>
                {aiOpponent.formLast5.map((r) => (
                  <li
                    aria-label={r}
                    class:list={["size-3 rounded-full border border-border", resultDot[r]]}
                  />
                ))}
              </ol>
            </div>

            {/* Streak block */}
            <div class="mt-4 flex items-baseline justify-between gap-3">
              <div>
                <p class="font-mono text-mono-sm uppercase text-muted-foreground">
                  Current streak
                </p>
                <p class="mt-1 font-display italic text-foreground tabular-nums leading-none text-3xl">
                  {aiOpponent.currentStreak}
                  <span class="ml-1 align-middle font-mono text-mono-md uppercase text-muted-foreground">W</span>
                </p>
              </div>
              <div class="text-right">
                <p class="font-mono text-mono-sm uppercase text-muted-foreground">
                  Longest
                </p>
                <p class="mt-1 font-mono tabular-nums text-foreground text-lg">
                  {aiOpponent.longestStreak}<span class="font-mono text-mono-sm uppercase text-muted-foreground">w</span>
                </p>
              </div>
            </div>
          </article>

          {/* ── Move history ─────────────────────────────────
              Compact column-numbers list. 2-up rows: 'you · column'
              on the left, 'ai · column' on the right. Connect-4 games
              rarely exceed ~25 moves so we keep all rows visible
              (overflow-y-auto kicks in if very long). */}
          <article class={cn(cardCls, "p-4")}>
            <header class="flex items-baseline justify-between gap-3">
              <p class="font-mono text-mono-md uppercase text-foreground">
                Moves
              </p>
              <p class="font-mono text-mono-sm uppercase text-muted-foreground tabular-nums">
                {moves.length}
              </p>
            </header>

            {moves.length === 0 ? (
              <p class="mt-4 font-mono text-mono-sm uppercase text-muted-foreground text-center">
                No moves yet.
              </p>
            ) : (
              <ol class="mt-3 max-h-56 overflow-y-auto pr-1">
                {/* Pair each "you" move with the immediate following
                    "ai" move on the same numbered row. */}
                {Array.from({ length: Math.ceil(moves.length / 2) }).map((_, i) => {
                  const youMove = moves[i * 2];
                  const aiMove  = moves[i * 2 + 1];
                  return (
                    <li class="grid grid-cols-[1.5rem_1fr_1fr] items-center gap-2 py-1">
                      <span class="font-mono text-mono-sm uppercase text-muted-foreground tabular-nums">
                        {youMove.num}
                      </span>
                      <span class="flex items-center gap-1.5">
                        <span aria-hidden="true" class="size-2 shrink-0 rounded-full bg-pawn-yellow" />
                        <span class="font-mono text-mono-md tabular-nums text-foreground">
                          {youMove.column}
                        </span>
                      </span>
                      {aiMove ? (
                        <span class="flex items-center gap-1.5">
                          <span aria-hidden="true" class="size-2 shrink-0 rounded-full bg-pawn-red" />
                          <span class="font-mono text-mono-md tabular-nums text-foreground">
                            {aiMove.column}
                          </span>
                        </span>
                      ) : (
                        <span aria-hidden="true" />
                      )}
                    </li>
                  );
                })}
              </ol>
            )}
          </article>

          {/* ── Game controls ────────────────────────────────
              New game = primary (brand-filled). Resign = secondary
              destructive (brand-outline). Hrefs are placeholders;
              wiring belongs in the lobby/game-button work item. */}
          <div class="flex flex-col gap-2">
            <a
              href="/play"
              data-todo-integration="POST /api/games/ai with current params, then redirect"
              class={cn(buttonVariants({ variant: "brand-filled", size: "pill" }), "w-full justify-center gap-1.5")}
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true">
                <polyline points="1 4 1 10 7 10" />
                <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10" />
              </svg>
              New game
            </a>
            <a
              href="/play"
              data-todo-integration="POST /api/games/:id/surrender (socket: game:surrender)"
              class={cn(buttonVariants({ variant: "brand-outline", size: "pill" }), "w-full justify-center gap-1.5 border-2")}
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true">
                <line x1="4" y1="22" x2="4" y2="15" />
                <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z" />
              </svg>
              Resign
            </a>
          </div>

        </div>
      </div>

    </div>
  </main>

  {/* SVG filter for the liquid-glass board variant. Identical to the
      one on landing — the variant references the filter via filter:url(#lg-dist)
      so it has to be in the document. */}
  <svg aria-hidden="true" style="position:absolute;width:0;height:0;pointer-events:none;">
    <defs>
      <filter id="lg-dist" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence type="fractalNoise" baseFrequency="0.008 0.008" numOctaves="2" seed="92" result="noise" />
        <feGaussianBlur in="noise" stdDeviation="2" result="blurred" />
        <feDisplacementMap in="SourceGraphic" in2="blurred" scale="70" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>
</RootLayout>
