---
/**
 * /how-to-play — Connect 4 rules + platform basics.
 * Static prose page. Editorial template matching /privacy + /terms.
 */
import RootLayout from "~/layouts/RootLayout.astro";

const sections = [
  {
    title: "The goal",
    body: `Connect 4 is played on a grid of 7 columns and 6 rows. Two players
      take turns dropping tokens into a column — a token falls to the lowest
      free slot. The first to line up four of their tokens in a row —
      horizontally, vertically, or diagonally — wins.`,
  },
  {
    title: "Taking a turn",
    body: `Click a column to drop your token. You can only play on your turn —
      the board shows whose turn it is. If the board fills with no four-in-a-row,
      it's a draw.`,
  },
  {
    title: "The clock",
    body: `Each player has a total time budget (chess-style), not a per-move
      limit. Your clock only counts down on your turn. Choose 5, 10, or 60
      minutes when creating a game. Run out of time and you lose.`,
  },
  {
    title: "Ways to play",
    body: `Against the AI — jump in instantly from the home page, no account
      needed, three difficulty levels. Against a friend — sign up, then create
      or join a lobby. Public lobbies are open to anyone; private ones need a
      code.`,
  },
  {
    title: "Forfeit & disconnect",
    body: `You can surrender at any time with the surrender button. If you lose
      connection, you have one minute to reconnect before the game is
      automatically abandoned.`,
  },
];
---

<RootLayout title="4thewin — How to play" description="Connect 4 rules and how to get started.">
  <main
    id="main"
    class="mx-auto w-full max-w-3xl flex-1 overflow-y-auto px-margin-mobile pt-[120px] pb-20 md:pt-[150px]"
  >
    <header class="flex flex-col gap-4">
      <span class="font-mono text-mono-sm uppercase text-accent">Guide</span>
      <h1 class="font-display text-5xl font-semibold tracking-tight text-foreground md:text-6xl">
        How to <span class="italic font-light">play</span>
      </h1>
    </header>

    <p class="mt-8 font-display text-xl font-light italic leading-relaxed text-foreground/70">
      Four in a row wins. Everything else is strategy.
    </p>

    <hr class="mt-10 border-t border-border" />

    <div class="mt-10 flex flex-col">
      {sections.map((s, i) => (
        <section class="grid gap-3 border-t border-border/60 py-8 first:border-t-0 md:grid-cols-[3rem_1fr] md:gap-8">
          <span class="font-mono text-mono-md text-accent md:pt-1">
            {String(i + 1).padStart(2, "0")}
          </span>
          <div class="flex flex-col gap-3">
            <h2 class="font-display text-2xl font-semibold tracking-tight text-foreground">
              {s.title}
            </h2>
            <p class="leading-relaxed text-foreground/80">{s.body}</p>
          </div>
        </section>
      ))}
    </div>

    <div class="mt-12 flex justify-center">
      <a
        href="/play"
        class="font-mono text-mono-md uppercase font-bold text-emphasis underline underline-offset-4 transition-opacity hover:opacity-70"
      >
        Start playing →
      </a>
    </div>
  </main>
</RootLayout>
