---
import RootLayout from "~/layouts/RootLayout.astro";

const sections = [
  {
    title: "L'objectif",
    body: `Le Puissance 4 se joue sur une grille de 7 colonnes et 6 lignes. Deux joueurs déposent à tour de rôle un jeton dans une colonne — le jeton tombe dans la case libre la plus basse. Le premier à aligner quatre jetons — horizontalement, verticalement ou en diagonale — gagne.`,
  },
  {
    title: "Jouer un coup",
    body: `Cliquez sur une colonne pour y déposer votre jeton. Vous ne pouvez jouer que pendant votre tour — le plateau indique à qui c'est le tour. Si la grille se remplit sans alignement de quatre, c'est un match nul.`,
  },
  {
    title: "Le chrono",
    body: `Chaque joueur dispose d'un temps total (style échecs), pas d'une limite par coup. Votre chrono ne décompte que pendant votre tour. Choisissez 5, 10 ou 60 minutes à la création d'une partie. Si votre temps est écoulé, vous perdez.`,
  },
  {
    title: "Les modes de jeu",
    body: `Contre l'IA — lancez une partie instantanément depuis l'accueil, sans compte, trois niveaux de difficulté. Contre un ami — inscrivez-vous, puis créez ou rejoignez un lobby. Les lobbies publics sont ouverts à tous ; les privés nécessitent un code.`,
  },
  {
    title: "Abandon & déconnexion",
    body: `Vous pouvez abandonner à tout moment via le bouton de reddition. Si vous perdez la connexion, vous avez une minute pour vous reconnecter avant que la partie ne soit automatiquement abandonnée.`,
  },
];
---

<RootLayout title="4thewin — Comment jouer" description="Règles du Puissance 4 et comment démarrer.">
  <main
    id="main"
    class="mx-auto w-full max-w-3xl flex-1 overflow-y-auto px-margin-mobile pt-[120px] pb-20 md:pt-[150px]"
  >
    <header class="page-reveal flex flex-col gap-4" style="--reveal-delay: 0.1s">
      <span class="font-mono text-mono-sm uppercase text-accent">Guide</span>
      <h1 class="font-display text-5xl font-semibold tracking-tight text-foreground md:text-6xl">
        Comment <span class="italic font-light">jouer</span>
      </h1>
    </header>

    <p class="page-reveal mt-8 font-display text-xl font-light italic leading-relaxed text-foreground/70" style="--reveal-delay: 0.25s">
      Quatre à la suite pour gagner. Le reste, c'est de la stratégie.
    </p>

    <hr class="page-reveal mt-10 border-t border-border" style="--reveal-delay: 0.35s" />

    <div class="mt-10 flex flex-col">
      {sections.map((s, i) => (
        <section
          class="page-reveal grid gap-3 border-t border-border/60 py-8 first:border-t-0 md:grid-cols-[3rem_1fr] md:gap-8"
          style={`--reveal-delay: ${0.4 + i * 0.1}s`}
        >
          <span class="font-mono text-mono-md text-accent md:pt-1">
            {String(i + 1).padStart(2, "0")}
          </span>
          <div class="flex flex-col gap-3">
            <h2 class="font-display text-2xl font-semibold tracking-tight text-foreground">
              {s.title}
            </h2>
            <p class="leading-relaxed text-foreground/80">{s.body}</p>
          </div>
        </section>
      ))}
    </div>

    <div class="page-reveal mt-12 flex justify-center" style="--reveal-delay: 1s">
      <a
        href="/play"
        class="font-mono text-mono-md uppercase font-bold text-emphasis underline underline-offset-4 transition-opacity hover:opacity-70"
      >
        Commencer à jouer →
      </a>
    </div>
  </main>
</RootLayout>