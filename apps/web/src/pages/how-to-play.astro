---
import RootLayout from "~/layouts/RootLayout.astro";

const sections = [
  {
    title: "The objective",
    body: `Connect 4 is played on a 7-column, 6-row grid. Two players take turns dropping a token into a column — the token falls to the lowest available cell. The first to connect four tokens in a row — horizontally, vertically, or diagonally — wins.`,
  },
  {
    title: "Making a move",
    body: `Click on a column to drop your token. You can only play during your turn — the board indicates whose turn it is. If the grid fills up without a four-in-a-row, it's a draw.`,
  },
  {
    title: "The timer",
    body: `Each player gets a total time (chess-style), not a per-move limit. Your timer only counts down during your turn. Choose 5, 10, or 60 minutes when creating a game. If your time runs out, you lose.`,
  },
  {
    title: "Game modes",
    body: `Against the AI — start a game instantly from the home page, no account needed, three difficulty levels. Against a friend — sign up, then create or join a lobby. Public lobbies are open to everyone; private ones require a code.`,
  },
  {
    title: "Forfeit & disconnection",
    body: `You can forfeit at any time via the surrender button. If you lose connection, you have one minute to reconnect before the game is automatically abandoned.`,
  },
];
---

<RootLayout title="4thewin — How to play" description="Connect 4 rules and how to get started.">
  <main
    id="main"
    class="mx-auto w-full max-w-3xl flex-1 px-margin-mobile pt-[120px] pb-20 md:pt-[150px]"
  >
    <header class="page-reveal flex flex-col gap-4" style="--reveal-delay: 0.1s">
      <span class="font-mono text-mono-sm uppercase text-accent">Guide</span>
      <h1 class="font-display text-5xl font-semibold tracking-tight text-foreground md:text-6xl">
        How to <span class="italic font-light">play</span>
      </h1>
    </header>

    <p class="page-reveal mt-8 font-display text-xl font-light italic leading-relaxed text-foreground/70" style="--reveal-delay: 0.25s">
      Four in a row to win. The rest is strategy.
    </p>

    <hr class="page-reveal mt-10 border-t border-border" style="--reveal-delay: 0.35s" />

    <div class="mt-10 flex flex-col">
      {sections.map((s, i) => (
        <section
          class="page-reveal grid gap-3 border-t border-border/60 py-8 first:border-t-0 md:grid-cols-[3rem_1fr] md:gap-8"
          style={`--reveal-delay: ${0.4 + i * 0.1}s`}
        >
          <span class="font-mono text-mono-md text-accent md:pt-1">
            {String(i + 1).padStart(2, "0")}
          </span>
          <div class="flex flex-col gap-3">
            <h2 class="font-display text-2xl font-semibold tracking-tight text-foreground">
              {s.title}
            </h2>
            <p class="leading-relaxed text-foreground/80">{s.body}</p>
          </div>
        </section>
      ))}
    </div>

    <div class="page-reveal mt-12 flex justify-center" style="--reveal-delay: 1s">
      <a
        href="/play"
        class="font-mono text-mono-md uppercase font-bold text-emphasis underline underline-offset-4 transition-opacity hover:opacity-70"
      >
        Start playing →
      </a>
    </div>
  </main>
</RootLayout>