---
/**
 * /styleguide — living inventory of the design system.
 *
 * Renders every token, primitive, and pattern in one place so a contributor
 * can eyeball the whole system after any change. Same code as production —
 * no separate Storybook to keep in sync.
 *
 * Sections mirror DESIGN.md:
 *   1. Foundations (colors, typography, spacing tokens)
 *   2. Components (Button, Input, FormField, AlertBox)
 *   3. Patterns (form layout, card composition)
 *   4. Domain visuals (pawn utilities)
 *
 * No auth gate — the page is harmless to expose. If we ever ship to a real
 * production env where this matters, gate it behind a `?dev` query param or
 * an env check.
 */
import RootLayout from "~/layouts/RootLayout.astro";
import { Button } from "~/components/ui/button";
import { Input } from "~/components/ui/input";
import { Label } from "~/components/ui/label";
import { FormField } from "~/components/ui/form-field";
import { AlertBox } from "~/components/ui/alert-box";
import { cn } from "~/lib/utils";

// Color tokens — name, css-var, where it's used.
const COLORS = [
  { name: "background", token: "--color-background", note: "page surface" },
  { name: "foreground", token: "--color-foreground", note: "primary text" },
  { name: "muted", token: "--color-muted", note: "subtle bg fills" },
  { name: "muted-foreground", token: "--color-muted-foreground", note: "secondary text" },
  { name: "border", token: "--color-border", note: "hairline strokes" },
  { name: "surface", token: "--color-surface", note: "raised cards" },
  { name: "accent", token: "--color-accent", note: "brand crimson" },
  { name: "destructive", token: "--color-destructive", note: "errors only" },
  { name: "ring", token: "--color-ring", note: "focus rings (brand)" },
  { name: "emphasis", token: "--color-emphasis", note: "scannable inline links" },
];

const PAWN_COLORS = [
  { name: "pawn-red", note: "default — warm crimson" },
  { name: "pawn-yellow", note: "AI piece — amber" },
  { name: "pawn-wine", note: "skin choice" },
  { name: "pawn-coral", note: "skin choice" },
  { name: "pawn-brick", note: "skin choice" },
];

const GRID_COLORS = [
  { name: "grid-linen", note: "default — page-bg-tinted" },
  { name: "grid-ink", note: "skin choice" },
  { name: "grid-slate", note: "skin choice" },
];

const TYPE_SCALE = [
  { name: "text-display", sample: "Display headlines", className: "font-display italic text-3xl md:text-4xl" },
  { name: "text-2xl", sample: "Section heads", className: "text-2xl font-medium" },
  { name: "text-base", sample: "Body copy", className: "text-base" },
  { name: "text-sm", sample: "Helper / small body", className: "text-sm" },
  { name: "text-mono-sm", sample: "MONO LABELS", className: "font-mono text-mono-sm uppercase" },
];
---

<RootLayout title="4thewin — Style guide" description="Design system reference.">
  <main id="main" class="mx-auto flex w-full max-w-5xl flex-col gap-16 px-margin-mobile pt-32 pb-16 md:px-margin-desktop">
    {/* Page header */}
    <header class="flex flex-col gap-4 border-b border-border pb-8">
      <p class="font-mono text-mono-sm uppercase text-muted-foreground">Reference</p>
      <h1 class="font-display italic font-light tracking-wide text-3xl md:text-5xl text-foreground leading-none">
        Style guide
      </h1>
      <p class="max-w-prose text-base text-muted-foreground">
        Every token, primitive, and pattern in the design system, on one page.
        Use it to eyeball changes after edits to <code class="font-mono text-sm">globals.css</code>
        or <code class="font-mono text-sm">components/ui/</code>.
      </p>
    </header>

    {/* §1 Foundations — Colors */}
    <section class="flex flex-col gap-6">
      <h2 class="font-display italic text-2xl text-foreground leading-none">1. Colors</h2>
      <p class="max-w-prose text-sm text-muted-foreground">
        Tokens defined in <code class="font-mono text-sm">apps/web/src/styles/globals.css</code>'s
        <code class="font-mono text-sm">@theme</code> block. Every color has a light + dark variant
        — toggle the theme via the nav to compare.
      </p>

      {/* Neutral / brand tokens */}
      <div class="flex flex-col gap-4 rounded-xl border border-border bg-muted p-6">
        <h3 class="font-mono text-mono-sm uppercase text-muted-foreground">Neutral &amp; brand</h3>
        <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-5">
          {COLORS.map((c) => (
            <div class="flex flex-col gap-2">
              <div class="h-16 rounded-md ring-2 ring-foreground/20 ring-inset" style={`background:var(${c.token})`}></div>
              <p class="font-mono text-mono-sm text-foreground">{c.name}</p>
              <p class="text-sm text-muted-foreground">{c.note}</p>
            </div>
          ))}
        </div>
      </div>

      {/* Pawn colors */}
      <div class="flex flex-col gap-4 rounded-xl border border-border bg-muted p-6">
        <h3 class="font-mono text-mono-sm uppercase text-muted-foreground">Pawn skins</h3>
        <div class="grid grid-cols-2 gap-4 md:grid-cols-5">
          {PAWN_COLORS.map((p) => (
            <div class="flex flex-col items-center gap-2">
              {/* Inline CSS variable instead of bg-{name} class — Tailwind's
                  class-scanner can't see through template-literal class names,
                  so e.g. bg-pawn-yellow (only used dynamically here) wouldn't
                  get generated, and the swatch would render as the page bg. */}
              <div
                class="size-12 rounded-full ring-2 ring-foreground/20 ring-inset"
                style={`background:var(--color-${p.name})`}
              ></div>
              <p class="font-mono text-mono-sm text-foreground">{p.name}</p>
              <p class="text-center text-sm text-muted-foreground">{p.note}</p>
            </div>
          ))}
        </div>
      </div>

      {/* Grid colors */}
      <div class="flex flex-col gap-4 rounded-xl border border-border bg-muted p-6">
        <h3 class="font-mono text-mono-sm uppercase text-muted-foreground">Grid skins</h3>
        <div class="grid grid-cols-3 gap-4 md:grid-cols-3">
          {GRID_COLORS.map((g) => (
            <div class="flex flex-col items-center gap-2">
              <div
                class="h-16 w-full rounded-md ring-2 ring-foreground/20 ring-inset"
                style={`background:var(--color-${g.name})`}
              ></div>
              <p class="font-mono text-mono-sm text-foreground">{g.name}</p>
              <p class="text-center text-sm text-muted-foreground">{g.note}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* §2 Foundations — Typography */}
    <section class="flex flex-col gap-6">
      <h2 class="font-display italic text-2xl text-foreground leading-none">2. Typography</h2>
      <div class="flex flex-col gap-6 rounded-xl border border-border bg-surface p-6">
        {TYPE_SCALE.map((t) => (
          <div class="flex flex-col gap-1 border-b border-border pb-4 last:border-b-0 last:pb-0">
            <p class="font-mono text-mono-sm text-muted-foreground">{t.name}</p>
            <p class={cn(t.className, "text-foreground")}>{t.sample}</p>
          </div>
        ))}
      </div>
    </section>

    {/* §3 Components — Buttons */}
    <section class="flex flex-col gap-6">
      <h2 class="font-display italic text-2xl text-foreground leading-none">3. Buttons</h2>
      <p class="max-w-prose text-sm text-muted-foreground">
        Variants in <code class="font-mono text-sm">components/ui/button.tsx</code>. The brand
        variants invert on hover — use them for nav CTAs (Sign up, Play). For form-submit
        buttons override the hover with <code class="font-mono text-sm">hover:bg-foreground/90</code>
        to avoid the inversion flicker on retry.
      </p>
      <div class="flex flex-col gap-6 rounded-xl border border-border bg-surface p-6">
        <div class="flex flex-col gap-3">
          <p class="font-mono text-mono-sm uppercase text-muted-foreground">brand-filled — pill</p>
          <div class="flex flex-wrap items-center gap-3">
            <Button variant="brand-filled" size="pill">Sign up</Button>
            <Button variant="brand-filled" size="pill" disabled>Disabled</Button>
            <Button variant="brand-filled" size="pill" className="hover:bg-foreground/90 hover:text-background">No-invert (forms)</Button>
          </div>
        </div>
        <div class="flex flex-col gap-3 border-t border-border pt-6">
          <p class="font-mono text-mono-sm uppercase text-muted-foreground">brand-outline — pill</p>
          <div class="flex flex-wrap items-center gap-3">
            <Button variant="brand-outline" size="pill">Login</Button>
            <Button variant="brand-outline" size="pill" disabled>Disabled</Button>
          </div>
        </div>
        <div class="flex flex-col gap-3 border-t border-border pt-6">
          <p class="font-mono text-mono-sm uppercase text-muted-foreground">ghost / icon</p>
          <div class="flex flex-wrap items-center gap-3">
            <Button variant="ghost" size="icon" aria-label="Menu">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4">
                <line x1="4" x2="20" y1="6" y2="6"></line>
                <line x1="4" x2="20" y1="12" y2="12"></line>
                <line x1="4" x2="20" y1="18" y2="18"></line>
              </svg>
            </Button>
          </div>
        </div>
      </div>
    </section>

    {/* §4 Components — Inputs + FormField */}
    <section class="flex flex-col gap-6">
      <h2 class="font-display italic text-2xl text-foreground leading-none">4. Inputs &amp; FormField</h2>
      <div class="grid gap-6 rounded-xl border border-border bg-surface p-6 md:grid-cols-2">
        <div class="flex flex-col gap-3">
          <p class="font-mono text-mono-sm uppercase text-muted-foreground">Label + Input (raw)</p>
          <Label htmlFor="sg-raw">Email</Label>
          <Input id="sg-raw" type="email" placeholder="name@example.com" />
        </div>
        <div class="flex flex-col gap-3">
          <p class="font-mono text-mono-sm uppercase text-muted-foreground">FormField — clean</p>
          <FormField id="sg-clean" label="Email" type="email" placeholder="name@example.com" hint="We'll never share this." />
        </div>
        <div class="flex flex-col gap-3 md:col-span-2">
          <p class="font-mono text-mono-sm uppercase text-muted-foreground">FormField — error</p>
          <FormField id="sg-err" label="Email" type="email" defaultValue="not-an-email" error="Use a valid email like name@example.com." />
        </div>
      </div>
    </section>

    {/* §5 Components — AlertBox */}
    <section class="flex flex-col gap-6">
      <h2 class="font-display italic text-2xl text-foreground leading-none">5. AlertBox</h2>
      <p class="max-w-prose text-sm text-muted-foreground">
        Form-level alert. Use the <code class="font-mono text-sm">action</code> prop to attach an
        inline CTA (e.g., "Sign in instead?" on a duplicate-email signup).
      </p>
      <div class="flex flex-col gap-4 rounded-xl border border-border bg-surface p-6">
        <AlertBox>Wrong email or password.</AlertBox>
        <AlertBox action={{ label: "Sign in instead?", href: "/login" }}>
          Couldn't create your account.
        </AlertBox>
        <AlertBox variant="info">Heads up — this account is read-only until you verify your email.</AlertBox>
      </div>
    </section>

    {/* §6 Patterns — Pawn token utility */}
    <section class="flex flex-col gap-6">
      <h2 class="font-display italic text-2xl text-foreground leading-none">6. Pawn utilities</h2>
      <p class="max-w-prose text-sm text-muted-foreground">
        The <code class="font-mono text-sm">pawn-red</code> / <code class="font-mono text-sm">pawn-yellow</code> /
        <code class="font-mono text-sm">pawn-neutral</code> utilities apply the dome+drop shadow recipe
        for actual game pieces. Use the bare <code class="font-mono text-sm">bg-pawn-*</code> token classes
        for flat color previews (skin pickers, etc).
      </p>
      <div class="flex flex-wrap gap-6 rounded-xl border border-border bg-surface p-6">
        <div class="flex flex-col items-center gap-2">
          <span class="size-12 rounded-full pawn-red"></span>
          <p class="font-mono text-mono-sm">pawn-red</p>
          <p class="text-sm text-muted-foreground">utility</p>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="size-12 rounded-full pawn-yellow"></span>
          <p class="font-mono text-mono-sm">pawn-yellow</p>
          <p class="text-sm text-muted-foreground">utility</p>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="size-12 rounded-full pawn-neutral"></span>
          <p class="font-mono text-mono-sm">pawn-neutral</p>
          <p class="text-sm text-muted-foreground">progress dot</p>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="size-12 rounded-full pawn-slot"></span>
          <p class="font-mono text-mono-sm">pawn-slot</p>
          <p class="text-sm text-muted-foreground">empty hole</p>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="size-12 rounded-full bg-pawn-red"></span>
          <p class="font-mono text-mono-sm">bg-pawn-red</p>
          <p class="text-sm text-muted-foreground">flat token</p>
        </div>
      </div>
    </section>

    {/* §7 Atmosphere — backdrop utilities */}
    <section class="flex flex-col gap-6">
      <h2 class="font-display italic text-2xl text-foreground leading-none">7. Atmosphere</h2>
      <p class="max-w-prose text-sm text-muted-foreground">
        Decorative backdrop utilities for staging hero content. Apply via an
        absolutely-positioned <code class="font-mono text-sm">aria-hidden</code> div with
        <code class="font-mono text-sm">-z-10</code> behind the main content.
      </p>
      <div class="relative h-64 overflow-hidden rounded-xl border border-border bg-background">
        <div class="stage-backdrop pointer-events-none absolute inset-0" aria-hidden="true"></div>
        <div class="relative flex h-full flex-col items-center justify-center gap-2">
          <p class="font-mono text-mono-sm uppercase text-muted-foreground">stage-backdrop</p>
          <p class="text-sm text-muted-foreground">warm radial halo, anchored low-center</p>
        </div>
      </div>
    </section>
  </main>
</RootLayout>
