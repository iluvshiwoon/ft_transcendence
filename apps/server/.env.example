# Connexion à PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Secret pour signer les JWT (au moins 32 caractères, doit rester privé)
JWT_SECRET=replace_with_random_32+_chars

# URL du frontend (pour la config CORS du back)
FRONTEND_URL=http://localhost:4321

# OAuth 42 (créer une app sur https://profile.intra.42.fr/oauth/applications)
OAUTH42_CLIENT_ID=your_42_app_uid
OAUTH42_CLIENT_SECRET=your_42_app_secret
OAUTH42_REDIRECT_URI=http://localhost:3000/api/auth/42/callback

# Vault (optionnel — si défini, les secrets ci-dessus sont écrasés par ceux de Vault au boot)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev_root_token
